{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "paths": {
      "@sunny-game/types": ["../../packages/types/src"],
      "@sunny-game/constants": ["../../packages/constants/src"],
      "@sunny-game/utils": ["../../packages/utils/src"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "../../packages"]
}
