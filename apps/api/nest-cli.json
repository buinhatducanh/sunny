{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "builder": {
      "type": "webpack",
      "options": {
        "configPath": "webpack.config.cjs"
      }
    },
    "webpack": true,
    "exec": "node dist/src/main.js",
    "typescript": {
      "ignoreBuildErrors": true
    }
  }
}
